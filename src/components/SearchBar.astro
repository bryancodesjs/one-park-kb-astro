---
interface Article {
  slug: string
  categorySlug: string
  title: string
  summary: string
  tags: string[]
}

interface Category {
  slug: string
  name: string
  icon: string
}

interface Props {
  articles: Article[]
  categories: Category[]
  placeholder?: string
  inputId?: string
  dropdownId?: string
  searchPageBase?: string
}

const {
  articles,
  categories,
  placeholder     = 'Search',
  inputId         = 'kb-search',
  dropdownId      = 'kb-search-dropdown',
  searchPageBase  = '/browse',
} = Astro.props
---

<div class="relative w-full" data-searchbar>
  <div class="flex items-center gap-3">
    <div class="relative focus-within:outline-2 outline-[#47BB60] flex-1 flex items-center justify-start rounded-full border border-[#dce8f2] bg-white pr-1">
      <label for={inputId} class="sr-only">Search</label>
      <input
        id={inputId}
        type="search"
        placeholder={placeholder}
        class="w-full h-[44px] pl-3   text-[15px] text-[#0A1628] placeholder:text-[#9CA3AF] focus:outline-none focus:border-[#012d53] transition-colors"
        autocomplete="off"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-autocomplete="list"
        aria-controls={dropdownId}
      />
      <button
        type="button"
        data-search-submit
        class="h-[38px] w-[38px] flex items-center justify-center rounded-full bg-[#47BB60] text-white text-[14px] font-semibold flex items-center gap-2 hover:bg-[#37954B] transition-colors shrink-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#012d53]"
        aria-label="Search"
      >
        <i class="ri-search-line text-base" aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <div
    id={dropdownId}
    role="listbox"
    aria-label="Search suggestions"
    data-dropdown
    class="absolute top-[calc(100%+8px)] left-0 right-0 bg-white border border-[#dce8f2] rounded-2xl shadow-lg overflow-hidden z-40 hidden"
  ></div>
</div>

<script define:vars={{ articles, categories, searchPageBase, inputId, dropdownId }}>
  (function () {
    const input     = document.getElementById(inputId)
    const dropdown  = document.getElementById(dropdownId)
    const container = input && input.closest('[data-searchbar]')
    const submitBtn = container && container.querySelector('[data-search-submit]')
    if (!input || !dropdown || !container) return

    let resultEls = []

    function esc(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
    }

    function catIcon(slug) {
      return categories.find(c => c.slug === slug)?.icon || 'ri-file-text-line'
    }

    function catName(slug) {
      return categories.find(c => c.slug === slug)?.name || ''
    }

    function runSearch(q) {
      if (q.length < 2) return []
      const lower = q.toLowerCase()
      return articles
        .filter(a =>
          a.title.toLowerCase().includes(lower) ||
          a.summary.toLowerCase().includes(lower) ||
          a.tags.some(t => t.toLowerCase().includes(lower))
        )
        .slice(0, 7)
    }

    function render(q) {
      const results = runSearch(q)

      if (q.length < 2) {
        close()
        return
      }

      dropdown.classList.remove('hidden')
      input.setAttribute('aria-expanded', 'true')

      if (results.length === 0) {
        dropdown.innerHTML = `
          <div class="px-5 py-4 text-sm text-[#6B7280]" role="option" aria-selected="false">
            No results for "<span class="font-semibold text-[#0A1628]">${esc(q)}</span>"
          </div>`
        resultEls = []
        return
      }

      const items = results.map(a => `
        <a href="/browse/${esc(a.categorySlug)}/${esc(a.slug)}"
           role="option" aria-selected="false" tabindex="-1"
           class="result-link flex items-start gap-3 px-5 py-3.5 hover:bg-[#f4f7fa] transition-colors border-b border-[#dce8f2] last:border-b-0 no-underline group">
          <div class="w-8 h-8 rounded-lg bg-[#dce8f2] flex items-center justify-center shrink-0 mt-0.5">
            <i class="${esc(catIcon(a.categorySlug))} text-[#012d53] text-sm" aria-hidden="true"></i>
          </div>
          <div class="flex flex-col gap-0.5 min-w-0">
            <span class="text-[14px] font-semibold text-[#0A1628] group-hover:text-[#012d53] transition-colors truncate">${esc(a.title)}</span>
            <span class="text-[12px] text-[#6B7280] truncate">${esc(catName(a.categorySlug))}</span>
          </div>
          <i class="ri-arrow-right-up-line text-[#012d53] text-sm ml-auto shrink-0 mt-1 opacity-0 group-hover:opacity-100 transition-opacity" aria-hidden="true"></i>
        </a>`).join('')

      const footer = `
        <button type="button" data-see-all
          class="w-full text-left px-5 py-3 text-[13px] font-semibold text-[#012d53] hover:bg-[#f4f7fa] transition-colors flex items-center gap-1.5">
          <i class="ri-search-line text-sm" aria-hidden="true"></i>
          See all results for "${esc(q)}"
        </button>`

      dropdown.innerHTML = items + footer
      resultEls = Array.from(dropdown.querySelectorAll('.result-link'))

      dropdown.querySelector('[data-see-all]')?.addEventListener('click', () => navigate())
    }

    function close() {
      input.value = ''
      dropdown.classList.add('hidden')
      input.setAttribute('aria-expanded', 'false')
      resultEls = []
    }

    function focusResult(idx) {
      if (!resultEls.length) return
      const clamped = Math.max(0, Math.min(idx, resultEls.length - 1))
      resultEls[clamped]?.focus()
    }

    function navigate() {
      const q = input.value.trim()
      if (q) window.location.href = `${searchPageBase}?q=${encodeURIComponent(q)}`
    }

    input.addEventListener('input', () => render(input.value.trim()))

    input.addEventListener('keydown', e => {
      if (e.key === 'Enter')     { navigate(); return }
      if (e.key === 'Escape')    { close(); return }
      if (e.key === 'ArrowDown') { e.preventDefault(); focusResult(0) }
    })

    dropdown.addEventListener('keydown', e => {
      const cur = resultEls.indexOf(document.activeElement)
      if (e.key === 'ArrowDown') { e.preventDefault(); focusResult(cur + 1) }
      if (e.key === 'ArrowUp')   { e.preventDefault(); cur <= 0 ? input.focus() : focusResult(cur - 1) }
      if (e.key === 'Escape')    { close(); input.focus() }
    })

    submitBtn?.addEventListener('click', navigate)

    document.addEventListener('mousedown', e => {
      if (!container.contains(e.target)) close()
    })
  })()
</script>

<style>
  input[type='search']::-webkit-search-cancel-button { display: none; }
</style>
