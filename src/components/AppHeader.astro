---
import SearchBar from "./SearchBar.astro";
import HeaderDecor from "./HeaderDecor.astro";
import { getCollection } from "astro:content";

const stripMd = (id: string) => id.replace(/\.md$/, "");

const allCategories = await getCollection("categories");
const allArticles = await getCollection("articles");
const categories = allCategories.sort((a, b) => a.data.order - b.data.order);

const searchArticles = allArticles.map((a) => {
  const [catSlug, articleFile] = a.id.split("/");
  return {
    slug: stripMd(articleFile),
    categorySlug: catSlug,
    title: a.data.title,
    summary: a.data.summary,
    tags: a.data.tags,
  };
});

const searchCategories = categories.map((c) => ({
  slug: stripMd(c.id),
  name: c.data.name,
  icon: c.data.icon,
}));
---

<header class="kb-header sticky top-0 z-50">
  <!-- Colored stripe with drifting decor + tagline -->
  <div class="kb-header__stripe relative">
    <HeaderDecor />
    <div
      class="relative z-10 max-w-[1440px] mx-auto px-6 h-[88px] flex items-center justify-between gap-6"
    >
      <!-- Brand -->
      <a
        href="/"
        class="flex items-center gap-2.5 no-underline shrink-0"
        aria-label="McKenzie Capital Knowledge Base — Home"
      >
        <img src="/logo-new.svg" class="w-[148px]" alt="McKenzie Capital" />
      </a>

      <!-- Tagline -->
      <div class="hidden md:flex flex-col items-center text-center px-4 min-w-0">
        <p
          class="text-white/95 text-[18px] md:text-[20px] font-extrabold tracking-tight leading-tight m-0 whitespace-nowrap"
        >
          Don't chase dreams &mdash; collect them.
        </p>
        <p
          class="text-white/55 text-[11px] font-semibold uppercase tracking-[0.18em] mt-1 m-0"
        >
          McKenzie Capital · Collections Knowledge Base
        </p>
      </div>

      <!-- User -->
      <div class="flex items-center justify-end text-right gap-3 shrink-0">
        <div class="hidden sm:flex flex-col text-white leading-tight">
          <span class="font-semibold text-[14px]">Ruth Lorenzo</span>
          <span class="opacity-60 text-[12px]">Rehab Specialist</span>
        </div>
        <div
          class="w-9 h-9 rounded-full flex items-center justify-center overflow-hidden shrink-0"
          style="background: rgba(255,255,255,0.22); border: 1.5px solid rgba(255,255,255,0.4);"
          aria-label="Signed in as Ruth Lorenzo"
        >
          <span class="text-[13px] font-bold text-white" aria-hidden="true"
            >RL</span
          >
        </div>
      </div>
    </div>
  </div>

  <!-- Search sub-bar -->
  <div class="kb-header__searchbar">
    <div
      class="max-w-[1440px] mx-auto px-6 py-3 flex items-center gap-3 md:gap-4"
    >
      <a
        href="/"
        class="kb-iconbtn shrink-0"
        aria-label="Knowledge Base — Home"
      >
        <i class="ri-home-5-line text-lg" aria-hidden="true"></i>
      </a>
      <a
        href="/browse"
        class="kb-iconbtn shrink-0"
        aria-label="Browse all categories"
      >
        <i class="ri-book-shelf-line text-lg" aria-hidden="true"></i>
      </a>
      <div class="flex-1 min-w-0">
        <SearchBar
          articles={searchArticles}
          categories={searchCategories}
          inputId="home-search"
          dropdownId="home-search-dropdown"
        />
      </div>
    </div>
  </div>
</header>

<style>
  .kb-header__stripe {
    background:
      radial-gradient(120% 120% at 0% 0%, #1e5c9e 0%, transparent 60%),
      radial-gradient(120% 120% at 100% 0%, #0e6b8e 0%, transparent 55%),
      linear-gradient(120deg, #012d53 0%, #0a3a6b 50%, #0e6b8e 100%);
    background-size:
      200% 200%,
      200% 200%,
      300% 300%;
    animation: kb-stripe 18s ease-in-out infinite;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  @keyframes kb-stripe {
    0%,
    100% {
      background-position:
        0% 0%,
        100% 0%,
        0% 50%;
    }
    50% {
      background-position:
        20% 30%,
        80% 20%,
        100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kb-header__stripe {
      animation: none;
    }
  }

  .kb-header__searchbar {
    background: #ffffff;
    border-bottom: 1px solid #dce8f2;
  }

  .kb-iconbtn {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    color: #012d53;
    background: #f4f7fa;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      transform 150ms ease;
  }

  .kb-iconbtn:hover {
    background: #dce8f2;
    color: #011f3b;
  }

  .kb-iconbtn:focus-visible {
    outline: 2px solid #012d53;
    outline-offset: 2px;
  }
</style>
