---

<div class="mt-14 pt-8 border-t border-[#dce8f2] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
  <p class="text-[14px] font-semibold text-[#374151] m-0">Was this helpful?</p>
  <div class="flex items-center gap-3">
    <button
      type="button"
      data-feedback="yes"
      aria-pressed="false"
      class="feedback-btn flex items-center gap-2 text-[13px] font-semibold px-4 py-2 rounded-full border border-[#dce8f2] text-[#374151] hover:border-[#012d53] hover:text-[#012d53] transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#012d53]"
    >
      <i class="ri-thumb-up-line" aria-hidden="true"></i>
      Yes, helpful
    </button>
    <button
      type="button"
      data-feedback="no"
      aria-pressed="false"
      class="feedback-btn flex items-center gap-2 text-[13px] font-semibold px-4 py-2 rounded-full border border-[#dce8f2] text-[#374151] hover:border-[#6B7280] hover:text-[#6B7280] transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#6B7280]"
    >
      <i class="ri-thumb-down-line" aria-hidden="true"></i>
      Not really
    </button>
  </div>
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-feedback]')

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const val = btn.dataset.feedback
      buttons.forEach(b => {
        b.setAttribute('aria-pressed', String(b.dataset.feedback === val))
      })
    })
  })
</script>

<style>
  .feedback-btn[aria-pressed='true'][data-feedback='yes'] {
    background-color: #dce8f2;
    border-color: #012d53;
    color: #012d53;
  }
  .feedback-btn[aria-pressed='true'][data-feedback='no'] {
    background-color: #f3f4f6;
    border-color: #9ca3af;
    color: #6b7280;
  }
</style>
