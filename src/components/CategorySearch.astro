---
interface Article {
  slug: string
  categorySlug: string
  title: string
  summary: string
  tags: string[]
}

interface Props {
  articles: Article[]
  categoryColor?: string
  placeholder?: string
  inputId?: string
}

const {
  articles,
  categoryColor = '#012d53',
  placeholder   = 'Search articles…',
  inputId       = 'cat-search',
} = Astro.props
---

<div>
  <div class="relative mb-8">
    <label for={inputId} class="sr-only">Search within category</label>
    <i class="ri-search-line absolute left-4 top-1/2 -translate-y-1/2 text-[#9CA3AF] text-base" aria-hidden="true"></i>
    <input
      id={inputId}
      type="search"
      placeholder={placeholder}
      class="w-full h-[46px] pl-10 pr-4 rounded-full border border-[#dce8f2] bg-white text-[14px] text-[#0A1628] placeholder:text-[#9CA3AF] focus:outline-none focus:border-[#012d53] transition-colors"
    />
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" data-article-grid>
    {articles.map(article => (
      <a
        href={`/browse/${article.categorySlug}/${article.slug}`}
        class="res-card group flex flex-col gap-3 p-5 rounded-2xl bg-white transition-all duration-200 no-underline border border-[#dce8f2] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
        style={`--cat-color: ${categoryColor}`}
        aria-label={article.title}
        data-title={article.title.toLowerCase()}
        data-summary={article.summary.toLowerCase()}
        data-tags={article.tags.join(' ').toLowerCase()}
      >
        <h3 class="res-title text-[15px] font-bold text-[#0A1628] leading-snug line-clamp-2 transition-colors duration-150 m-0">
          {article.title}
        </h3>
      </a>
    ))}
  </div>

  <p class="text-[15px] text-[#6B7280] py-12 text-center hidden" data-no-results>
    No articles match "<span class="font-semibold text-[#0A1628]" data-no-results-term></span>"
  </p>
</div>

<script define:vars={{ inputId }}>
  (function () {
    const input     = document.getElementById(inputId)
    const grid      = document.querySelector('[data-article-grid]')
    const noResults = document.querySelector('[data-no-results]')
    const noTerm    = document.querySelector('[data-no-results-term]')
    if (!input || !grid) return

    const cards = Array.from(grid.querySelectorAll('[data-title]'))

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim()
      let visible = 0

      cards.forEach(card => {
        const match =
          !q ||
          card.dataset.title.includes(q) ||
          card.dataset.summary.includes(q) ||
          card.dataset.tags.includes(q)
        card.style.display = match ? '' : 'none'
        if (match) visible++
      })

      if (noResults) {
        noResults.classList.toggle('hidden', !q || visible > 0)
        if (noTerm) noTerm.textContent = input.value
      }
    })
  })()
</script>

<style>
  .res-card:hover                { border-color: var(--cat-color); box-shadow: 0 4px 12px -2px rgb(0 0 0 / 0.1); }
  .res-card:focus-visible        { outline-color: var(--cat-color); }
  .res-card:hover .res-title     { color: var(--cat-color); }
  input[type='search']::-webkit-search-cancel-button { display: none; }
</style>
