---
import BaseLayout from "../layouts/BaseLayout.astro";
import SuggestProcess from "../components/SuggestProcess.astro";
import { getCollection } from "astro:content";
import { holidaysForMonth } from "../lib/holidays";

const stripMd = (id: string) => id.replace(/\.md$/, "");

// ── Content ─────────────────────────────────────────────────────────────────
const allCategories = await getCollection("categories");
const allArticles = await getCollection("articles");
const allAnnouncements = await getCollection("announcements");
const allAlerts = await getCollection("alerts");

const categories = allCategories
  .filter((c) => !c.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

function articlesFor(catSlug: string) {
  return allArticles
    .filter((a) => a.id.startsWith(catSlug + "/") && !a.data.draft)
    .sort((a, b) => a.data.order - b.data.order)
    .map((a) => {
      const [, articleFile] = a.id.split("/");
      return {
        slug: stripMd(articleFile),
        title: a.data.title,
        readTime: a.data.readTime,
      };
    });
}

const groupMeta = {
  processes: {
    label: "Processes & Procedures",
    icon: "ri-flow-chart",
    accent: "#012d53",
    accent2: "#1e5c9e",
  },
  scripts: {
    label: "Scripts & Flows",
    icon: "ri-mic-line",
    accent: "#0e6b8e",
    accent2: "#22d3ee",
  },
  policy: {
    label: "Policy",
    icon: "ri-shield-keyhole-line",
    accent: "#9333ea",
    accent2: "#c026d3",
  },
  "call-library": {
    label: "Call Library",
    icon: "ri-headphone-line",
    accent: "#b45309",
    accent2: "#fb7185",
  },
} as const;

type GroupKey = keyof typeof groupMeta;

const groups: GroupKey[] = ["processes", "scripts", "policy", "call-library"];

const grouped = groups.map((g) => ({
  key: g,
  meta: groupMeta[g],
  categories: categories
    .filter((c) => c.data.group === g)
    .map((c) => {
      const slug = stripMd(c.id);
      return {
        slug,
        name: c.data.name,
        icon: c.data.icon,
        color: c.data.color,
        bgColor: c.data.bgColor,
        gradient: c.data.gradient,
        articles: articlesFor(slug),
      };
    }),
}));

// ── What's New feed (process-flavored) ─────────────────────────────────────
const feedArticles = [...allArticles]
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.dateCreated.localeCompare(a.data.dateCreated))
  .slice(0, 5)
  .map((a) => {
    const [catSlug, articleFile] = a.id.split("/");
    const cat = categories.find((c) => stripMd(c.id) === catSlug);
    return {
      slug: stripMd(articleFile),
      categorySlug: catSlug,
      title: a.data.title,
      summary: a.data.summary,
      readTime: a.data.readTime,
      dateCreated: a.data.dateCreated,
      categoryName: cat?.data.name ?? "",
      categoryColor: cat?.data.color ?? "#012d53",
      categoryBg: cat?.data.bgColor ?? "#dce8f2",
      categoryIcon: cat?.data.icon ?? "ri-file-text-line",
      groupKey: (cat?.data.group ?? "processes") as GroupKey,
    };
  });

// ── Announcements (Liliam) ─────────────────────────────────────────────────
const announcements = allAnnouncements
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.datePosted.localeCompare(a.data.datePosted))
  .map((a) => ({ ...a.data, body: a.body }));

// ── Alerts ─────────────────────────────────────────────────────────────────
const alerts = allAlerts
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.datePosted.localeCompare(a.data.datePosted))
  .map((a) => a.data);

// ── Calendar (April 2026) ──────────────────────────────────────────────────
const calYear = 2026;
const calMonth = 3; // April (0-indexed)
const firstDay = new Date(calYear, calMonth, 1).getDay(); // 0=Sun
const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
const calDays: (number | null)[] = [
  ...Array<null>(firstDay).fill(null),
  ...Array.from({ length: daysInMonth }, (_, i) => i + 1),
];
while (calDays.length % 7 !== 0) calDays.push(null);
const calWeeks: (number | null)[][] = [];
for (let i = 0; i < calDays.length; i += 7) {
  calWeeks.push(calDays.slice(i, i + 7));
}
const todayDate = 27;
const monthHolidays = holidaysForMonth(calYear, calMonth);
const monthLabel = new Date(calYear, calMonth, 1).toLocaleString("en-US", {
  month: "long",
  year: "numeric",
});

const alertKindStyles: Record<string, { bg: string; border: string; icon: string; iconColor: string; titleColor: string; bodyColor: string }> = {
  info: {
    bg: "#f0fdf4",
    border: "#bbf7d0",
    icon: "ri-information-line",
    iconColor: "#059669",
    titleColor: "#065f46",
    bodyColor: "#047857",
  },
  warning: {
    bg: "#fffbeb",
    border: "#fde68a",
    icon: "ri-error-warning-line",
    iconColor: "#d97706",
    titleColor: "#92400e",
    bodyColor: "#b45309",
  },
  danger: {
    bg: "#fef2f2",
    border: "#fecaca",
    icon: "ri-calendar-close-line",
    iconColor: "#dc2626",
    titleColor: "#991b1b",
    bodyColor: "#b91c1c",
  },
  weather: {
    bg: "#eff6ff",
    border: "#bfdbfe",
    icon: "ri-cloud-windy-line",
    iconColor: "#1d4ed8",
    titleColor: "#1e3a8a",
    bodyColor: "#1e40af",
  },
};
---

<BaseLayout title="Home — McKenzie Capital Knowledge Base">
  <div class="max-w-[1440px] mx-auto px-6 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 items-start">
      <!-- ══════════════════════════════════════════════════════
           LEFT — Knowledge: 4 grouped accordions
      ══════════════════════════════════════════════════════ -->
      <aside class="col-span-1 lg:col-span-4 flex flex-col gap-4">
        {
          grouped.map((group) => (
            <section
              class="kb-group rounded-2xl bg-white shadow-[0_1px_4px_rgb(0_0_0/0.07)] overflow-hidden"
              style={`--g-accent: ${group.meta.accent}; --g-accent2: ${group.meta.accent2};`}
              aria-labelledby={`group-${group.key}`}
            >
              <header class="kb-group__head px-5 py-4 flex items-center gap-3">
                <div
                  class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0 text-white"
                  style={`background: linear-gradient(135deg, ${group.meta.accent} 0%, ${group.meta.accent2} 100%);`}
                  aria-hidden="true"
                >
                  <i class:list={[group.meta.icon, "text-base"]} />
                </div>
                <h2
                  id={`group-${group.key}`}
                  class="text-[14px] font-extrabold tracking-tight m-0"
                  style={`color: ${group.meta.accent};`}
                >
                  {group.meta.label}
                </h2>
                <span class="ml-auto text-[11px] font-semibold text-[#9CA3AF]">
                  {group.categories.length}
                </span>
              </header>

              <div class="divide-y divide-[#f0f4f8]">
                {group.categories.map((cat) => (
                  <details class="kb-cat group">
                    <summary
                      class="kb-cat__row flex items-center gap-3 px-5 py-2.5 cursor-pointer no-underline list-none"
                      style={`--cat-color: ${cat.color};`}
                    >
                      <div
                        class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0"
                        style={`background: ${cat.bgColor};`}
                        aria-hidden="true"
                      >
                        <i
                          class:list={[cat.icon, "text-xs"]}
                          style={`color: ${cat.color};`}
                        />
                      </div>
                      <span class="kb-cat__title text-[13px] font-semibold text-[#0A1628] truncate flex-1">
                        {cat.name}
                      </span>
                      <span class="text-[11px] font-medium text-[#9CA3AF]">
                        {cat.articles.length}
                      </span>
                      <i
                        class="kb-cat__chev ri-arrow-down-s-line text-[#9CA3AF] text-base shrink-0 transition-transform"
                        aria-hidden="true"
                      />
                    </summary>

                    {cat.articles.length > 0 && (
                      <ul class="kb-cat__list pb-2 pl-[52px] pr-5 list-none m-0">
                        {cat.articles.map((art) => (
                          <li class="m-0">
                            <a
                              href={`/browse/${cat.slug}/${art.slug}`}
                              class="kb-cat__item flex items-center gap-2 py-1.5 text-[12.5px] text-[#374151] no-underline rounded-md hover:text-[var(--cat-color)] transition-colors"
                              style={`--cat-color: ${cat.color};`}
                            >
                              <i
                                class="ri-corner-down-right-line text-[#9CA3AF] text-xs shrink-0"
                                aria-hidden="true"
                              />
                              <span class="truncate flex-1">{art.title}</span>
                              <span class="text-[10px] text-[#9CA3AF] shrink-0">
                                {art.readTime}
                              </span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}

                    {cat.articles.length === 0 && (
                      <p class="text-[12px] text-[#9CA3AF] px-5 pb-3 pl-[52px] m-0 italic">
                        No entries yet.
                      </p>
                    )}
                  </details>
                ))}
              </div>
            </section>
          ))
        }
      </aside>

      <!-- ══════════════════════════════════════════════════════
           CENTER — What's New, Announcements, Suggest
      ══════════════════════════════════════════════════════ -->
      <main class="col-span-1 lg:col-span-5 flex flex-col gap-5 min-w-0">
        <!-- What's New -->
        <section
          class="bg-white rounded-2xl shadow-[0_1px_4px_rgb(0_0_0/0.07)] overflow-hidden"
        >
          <div class="flex items-center justify-between p-5">
            <h2
              class="text-[15px] font-bold text-[#012d53] m-0 flex items-center gap-2"
            >
              <i
                class="ri-sparkling-line text-[#0e6b8e]"
                aria-hidden="true"></i>
              What's New
            </h2>
            <a
              href="/browse"
              class="text-[12px] font-semibold text-[#0e6b8e] hover:text-[#0a4f6a] hover:underline no-underline transition-colors flex items-center gap-1"
            >
              View all <i
                class="ri-arrow-right-s-line"
                aria-hidden="true"></i>
            </a>
          </div>
          <div class="flex flex-col">
            {
              feedArticles.map((article) => (
                <a
                  href={`/browse/${article.categorySlug}/${article.slug}`}
                  class="feed-article group flex gap-4 p-4 border-b border-[#f0f4f8] last:border-b-0 hover:bg-[#f4f7fa] transition-all no-underline"
                >
                  <div
                    class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5"
                    style={`background: ${article.categoryBg}`}
                    aria-hidden="true"
                  >
                    <i
                      class:list={[article.categoryIcon, "text-sm"]}
                      style={`color: ${article.categoryColor}`}
                      aria-hidden="true"
                    />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span
                        class="text-[10px] font-bold uppercase tracking-wider"
                        style={`color: ${article.categoryColor}`}
                      >
                        {article.categoryName}
                      </span>
                      <span class="text-[#dce8f2]" aria-hidden="true">·</span>
                      <span class="text-[11px] text-[#9CA3AF]">
                        {article.readTime}
                      </span>
                      <span class="text-[#dce8f2]" aria-hidden="true">·</span>
                      <span class="text-[11px] text-[#9CA3AF]">
                        {new Date(article.dateCreated).toLocaleDateString(
                          "en-US",
                          { month: "short", day: "numeric" },
                        )}
                      </span>
                    </div>
                    <h3 class="feed-title text-[14px] font-semibold text-[#0A1628] leading-snug m-0 line-clamp-1 transition-colors">
                      {article.title}
                    </h3>
                    <p class="text-[12px] text-[#6B7280] mt-1 m-0 line-clamp-2 leading-relaxed">
                      {article.summary}
                    </p>
                  </div>
                  <i
                    class="ri-arrow-right-up-line text-sm ml-auto shrink-0 mt-1 opacity-0 group-hover:opacity-100 transition-opacity"
                    style={`color: ${article.categoryColor}`}
                    aria-hidden="true"
                  />
                </a>
              ))
            }
          </div>
        </section>

        <!-- Announcements (Liliam) -->
        <section
          class="bg-white rounded-2xl shadow-[0_1px_4px_rgb(0_0_0/0.07)] overflow-hidden"
        >
          <div class="flex items-center justify-between p-5">
            <h2
              class="text-[15px] font-bold text-[#012d53] m-0 flex items-center gap-2"
            >
              <i
                class="ri-megaphone-line text-[#9333ea]"
                aria-hidden="true"></i>
              Announcements
            </h2>
            <span
              class="text-[10px] font-bold uppercase tracking-wider text-white bg-[#9333ea] px-2.5 py-0.5 rounded-full"
            >
              From Liliam
            </span>
          </div>

          <div class="flex flex-col">
            {
              announcements.map((post) => (
                <article class="p-4 hover:bg-[#fbf7ff] border-b border-[#f0f4f8] last:border-b-0 transition-colors">
                  <div class="flex items-start gap-3">
                    <div
                      class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 text-white text-[12px] font-bold"
                      style={`background: ${post.avatarGradient};`}
                      aria-hidden="true"
                    >
                      {post.initials}
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <span class="text-[13px] font-bold text-[#012d53]">
                          {post.author}
                        </span>
                        {post.role && (
                          <span class="text-[11px] text-[#9CA3AF] font-medium">
                            {post.role}
                          </span>
                        )}
                        <span class="text-[#dce8f2]" aria-hidden="true">·</span>
                        <span class="text-[11px] text-[#9CA3AF]">
                          {new Date(post.datePosted).toLocaleDateString(
                            "en-US",
                            { month: "short", day: "numeric" },
                          )}
                        </span>
                        {post.isNew && (
                          <span class="ml-auto text-[10px] font-bold uppercase tracking-wider text-[#9333ea] bg-[#f3e8ff] px-2 py-0.5 rounded-full">
                            New
                          </span>
                        )}
                      </div>
                      <p class="text-[13px] font-bold text-[#0A1628] m-0 mb-1">
                        {post.title}
                      </p>
                      <p class="text-[13px] text-[#374151] leading-relaxed m-0">
                        {post.body}
                      </p>
                      {post.linkText && post.linkHref && (
                        <a
                          href={post.linkHref}
                          class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#9333ea] mt-2 no-underline hover:text-[#7e22ce] transition-colors"
                        >
                          {post.linkIcon && (
                            <i
                              class:list={[post.linkIcon, "text-xs"]}
                              aria-hidden="true"
                            />
                          )}
                          {post.linkText}
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <!-- Suggest a Process -->
        <SuggestProcess />
      </main>

      <!-- ══════════════════════════════════════════════════════
           RIGHT — Calendar · Schedule · Goal · Alerts
      ══════════════════════════════════════════════════════ -->
      <aside
        class="col-span-1 lg:col-span-3 flex flex-col gap-4 lg:sticky lg:top-[160px]"
      >
        <!-- Calendar -->
        <div
          class="bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <div class="flex items-center justify-between mb-4">
            <div>
              <p
                class="text-[30px] font-extrabold text-[#012d53] leading-none m-0"
              >
                {todayDate}
              </p>
              <p class="text-[12px] text-[#9CA3AF] font-medium mt-0.5 m-0">
                Monday, {monthLabel}
              </p>
            </div>
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center"
              style="background: linear-gradient(135deg, #012d53 0%, #1e5c9e 100%);"
              aria-hidden="true"
            >
              <i class="ri-calendar-2-line text-white text-base"></i>
            </div>
          </div>

          <div role="grid" aria-label={monthLabel}>
            <div class="grid grid-cols-7 mb-1" role="row">
              {
                ["S", "M", "T", "W", "T", "F", "S"].map((d) => (
                  <span
                    role="columnheader"
                    class="text-[10px] font-bold text-[#9CA3AF] text-center py-1"
                  >
                    {d}
                  </span>
                ))
              }
            </div>
            {
              calWeeks.map((week) => (
                <div class="grid grid-cols-7" role="row">
                  {week.map((day) => {
                    if (day === null) {
                      return <span role="gridcell" aria-hidden="true" />;
                    }
                    const holiday = monthHolidays.get(day);
                    const isToday = day === todayDate;
                    return (
                      <span
                        role="gridcell"
                        class:list={[
                          "relative text-[12px] text-center py-1.5 rounded-lg font-medium leading-none",
                          isToday
                            ? "bg-[#012d53] text-white font-bold"
                            : "text-[#374151] hover:bg-[#f4f7fa] cursor-default",
                        ]}
                        aria-current={isToday ? "date" : undefined}
                        title={holiday ? holiday.name : undefined}
                      >
                        {day}
                        {holiday && (
                          <span
                            class="cal-holiday-dot"
                            style={
                              isToday
                                ? "background: #fff;"
                                : "background: #c026d3;"
                            }
                            aria-hidden="true"
                          />
                        )}
                      </span>
                    );
                  })}
                </div>
              ))
            }
          </div>

          <div class="flex items-center gap-1.5 mt-3 pt-3 border-t border-[#f0f4f8]">
            <span
              class="w-1.5 h-1.5 rounded-full bg-[#c026d3] inline-block"
              aria-hidden="true"></span>
            <span class="text-[10px] text-[#9CA3AF] font-medium"
              >Federal holiday</span
            >
          </div>
        </div>

        <!-- Today's Schedule -->
        <div
          class="hidden bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <h2
            class="text-[14px] font-bold text-[#012d53] m-0 mb-3 flex items-center gap-2"
          >
            <i class="ri-time-line text-[#41be5e]" aria-hidden="true"></i>
            Today
          </h2>
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-3">
              <div
                class="w-1 h-10 rounded-full bg-[#41be5e] shrink-0"
                aria-hidden="true"
              >
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[11px] text-[#9CA3AF] m-0">10:00 AM</p>
                <p class="text-[13px] font-semibold text-[#012d53] m-0">
                  Team Huddle
                </p>
              </div>
              <i
                class="ri-group-line text-[#9CA3AF] text-sm shrink-0"
                aria-hidden="true"></i>
            </div>

            <div class="flex items-center gap-3">
              <div
                class="w-1 h-10 rounded-full bg-[#1e5c9e] shrink-0"
                aria-hidden="true"
              >
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[11px] text-[#9CA3AF] m-0">2:00 PM</p>
                <p class="text-[13px] font-semibold text-[#012d53] m-0">
                  Pipeline Review
                </p>
              </div>
              <i
                class="ri-bar-chart-line text-[#9CA3AF] text-sm shrink-0"
                aria-hidden="true"></i>
            </div>

            <div class="flex items-center gap-3">
              <div
                class="w-1 h-10 rounded-full bg-[#9333ea] shrink-0"
                aria-hidden="true"
              >
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[11px] text-[#9CA3AF] m-0">4:30 PM</p>
                <p class="text-[13px] font-semibold text-[#012d53] m-0">
                  Manager 1:1
                </p>
              </div>
              <i
                class="ri-user-line text-[#9CA3AF] text-sm shrink-0"
                aria-hidden="true"></i>
            </div>
          </div>
        </div>

        <!-- Collection Goal -->
        <div
          class="bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <h2
            class="text-[14px] font-bold text-[#012d53] m-0 mb-4 flex items-center gap-2"
          >
            <i class="ri-funds-line text-[#41be5e]" aria-hidden="true"></i>
            Collection Goal
          </h2>

          <div>
            <div class="flex justify-between items-baseline mb-1.5">
              <span class="text-[12px] font-semibold text-[#374151]"
                >This Week</span
              >
              <span class="text-[12px] font-bold text-[#012d53]">
                $47,200 <span class="font-medium text-[#9CA3AF]">/ $60k</span>
              </span>
            </div>
            <div
              class="h-2.5 rounded-full bg-[#dce8f2] overflow-hidden"
              role="progressbar"
              aria-valuenow={79}
              aria-valuemin={0}
              aria-valuemax={100}
            >
              <div
                class="h-full rounded-full"
                style="width: 79%; background: linear-gradient(90deg, #41be5e 0%, #34c97e 100%);"
              >
              </div>
            </div>
            <p class="text-[11px] text-[#9CA3AF] mt-1.5 m-0">
              79% · $12,800 to go
            </p>
          </div>
        </div>

        <!-- Alerts -->
        <div
          class="bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <h2
            class="text-[14px] font-bold text-[#012d53] m-0 mb-3 flex items-center gap-2"
          >
            <i
              class="ri-notification-3-line text-[#fb7185]"
              aria-hidden="true"></i>
            Alerts
          </h2>
          <div class="flex flex-col gap-2">
            {
              alerts.map((a) => {
                const s = alertKindStyles[a.kind] ?? alertKindStyles.info;
                return (
                  <div
                    class="flex items-start gap-3 p-3 rounded-xl border"
                    style={`background: ${s.bg}; border-color: ${s.border};`}
                  >
                    <i
                      class:list={[s.icon, "text-base mt-0.5 shrink-0"]}
                      style={`color: ${s.iconColor};`}
                      aria-hidden="true"
                    />
                    <div>
                      <p
                        class="text-[12px] font-semibold m-0"
                        style={`color: ${s.titleColor};`}
                      >
                        {a.title}
                      </p>
                      <p
                        class="text-[11px] m-0 mt-0.5"
                        style={`color: ${s.bodyColor};`}
                      >
                        {a.body}
                      </p>
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

