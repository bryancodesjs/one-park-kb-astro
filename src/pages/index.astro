---
import BaseLayout from "../layouts/BaseLayout.astro";
import SearchBar from "../components/SearchBar.astro";
import { getCollection } from "astro:content";

const stripMd = (id: string) => id.replace(/\.md$/, "");

const allCategories = await getCollection("categories");
const allArticles = await getCollection("articles");

const categories = allCategories.sort((a, b) => a.data.order - b.data.order);
const featuredCategories = categories.filter((c) => c.data.featured);

function articleCount(catSlug: string) {
  return allArticles.filter((a) => a.id.startsWith(catSlug + "/")).length;
}

const quickAccessArticles = allArticles
  .filter((a) => a.data.quickAccess)
  .slice(0, 5)
  .map((a) => {
    const [catSlug, articleFile] = a.id.split("/");
    const cat = categories.find((c) => stripMd(c.id) === catSlug);
    return {
      slug: stripMd(articleFile),
      categorySlug: catSlug,
      title: a.data.title,
      readTime: a.data.readTime,
      categoryName: cat?.data.name ?? "",
      categoryGradient: cat?.data.gradient ?? "",
      categoryColor: cat?.data.color ?? "#012d53",
      categoryIcon: cat?.data.icon ?? "ri-file-text-line",
    };
  });

const feedArticles = [...allArticles]
  .sort((a, b) => b.data.dateCreated.localeCompare(a.data.dateCreated))
  .slice(0, 5)
  .map((a) => {
    const [catSlug, articleFile] = a.id.split("/");
    const cat = categories.find((c) => stripMd(c.id) === catSlug);
    return {
      slug: stripMd(articleFile),
      categorySlug: catSlug,
      title: a.data.title,
      summary: a.data.summary,
      readTime: a.data.readTime,
      dateCreated: a.data.dateCreated,
      categoryName: cat?.data.name ?? "",
      categoryColor: cat?.data.color ?? "#012d53",
      categoryBg: cat?.data.bgColor ?? "#dce8f2",
      categoryIcon: cat?.data.icon ?? "ri-file-text-line",
    };
  });

const searchArticles = allArticles.map((a) => {
  const [catSlug, articleFile] = a.id.split("/");
  return {
    slug: stripMd(articleFile),
    categorySlug: catSlug,
    title: a.data.title,
    summary: a.data.summary,
    tags: a.data.tags,
  };
});

const searchCategories = categories.map((c) => ({
  slug: stripMd(c.id),
  name: c.data.name,
  icon: c.data.icon,
}));

const recentSearches = ["RBF rates", "Spouse objection", "FICO minimum"];

// April 2026 calendar — April 1 = Wednesday (Sun=0 → offset 3)
const calDays: (number | null)[] = [
  ...Array<null>(3).fill(null),
  ...Array.from({ length: 30 }, (_, i) => i + 1),
];
while (calDays.length % 7 !== 0) calDays.push(null);
const calWeeks: (number | null)[][] = [];
for (let i = 0; i < calDays.length; i += 7) {
  calWeeks.push(calDays.slice(i, i + 7));
}
const todayDate = 9;
---

<BaseLayout title="Home — McKenzie Capital Knowledge Base">
  <div class="max-w-[1440px] mx-auto px-6 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-6 gap-5 items-start">
      <!-- ══════════════════════════════════════════════════════
           LEFT — Search · Browse · Quick Access
      ══════════════════════════════════════════════════════ -->
      <aside
        class="col-span-1 lg:col-span-3 flex flex-col gap-4 lg:sticky lg:top-[80px]"
      >
        <!-- Welcome + Search -->
        <div
          class="hidden bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <div class="mb-4">
            <h1
              class="text-[18px] font-extrabold text-[#012d53] tracking-tight leading-tight"
            >
              Welcome back, Ruth
            </h1>
            <p class="text-[12px] text-[#9CA3AF] mt-1 m-0">
              Wednesday, April 9 · 3 events today
            </p>
          </div>
          <SearchBar
            articles={searchArticles}
            categories={searchCategories}
            inputId="hero-search"
            dropdownId="hero-search-dropdown"
          />
          <div class="mt-3" aria-label="Recent searches">
            <p
              class="text-[11px] font-semibold text-[#9CA3AF] uppercase tracking-widest mb-2 m-0"
            >
              Recent searches
            </p>
            <div class="flex flex-wrap gap-1.5">
              {
                recentSearches.map((search) => (
                  <a
                    href={`/browse?q=${encodeURIComponent(search)}`}
                    class="text-[12px] font-medium text-[#012d53] border border-[#b5cfe6] bg-[#f4f7fa] px-3 py-1 rounded-full hover:bg-white hover:border-[#012d53] transition-colors no-underline"
                  >
                    {search}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Quick Access -->
        <div
          class="bg-white rounded-2xl overflow-hidden shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <div class="flex items-center justify-between px-5 pt-5 pb-3">
            <h2
              class="text-[14px] font-bold text-[#012d53] m-0 flex items-center gap-1.5"
            >
              <i class="ri-flashlight-line text-blue-500" aria-hidden="true"
              ></i>
              Quick Access
            </h2>
            <a
              href="/browse"
              class="text-[12px] font-semibold text-blue-500 hover:text-blue-600 hover:underline no-underline transition-colors"
            >
              All
            </a>
          </div>
          <div class="flex flex-col divide-y divide-[#dce8f2]">
            {
              quickAccessArticles.map((article) => (
                <a
                  href={`/browse/${article.categorySlug}/${article.slug}`}
                  class="qa-row flex items-center gap-3 px-5 py-3 hover:bg-[#f4f7fa] transition-colors group no-underline"
                  style={`--cat-color: ${article.categoryColor}`}
                >
                  <div
                    class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0"
                    style={`background: ${article.categoryGradient}`}
                    aria-hidden="true"
                  >
                    <i
                      class:list={[article.categoryIcon, "text-xs text-white"]}
                      aria-hidden="true"
                    />
                  </div>
                  <div class="flex flex-col min-w-0">
                    <span class="qa-title text-[13px] font-semibold text-[#0A1628] transition-colors truncate">
                      {article.title}
                    </span>
                    <span class="text-[11px] text-[#9CA3AF]">
                      {article.readTime}
                    </span>
                  </div>
                  <i
                    class="qa-arrow ri-arrow-right-line ml-auto shrink-0 group-hover:translate-x-1 transition-transform text-xs"
                    aria-hidden="true"
                  />
                </a>
              ))
            }
          </div>
        </div>

        <!-- Featured Categories (compact) -->
        <div
          class="bg-white rounded-2xl shadow-[0_1px_4px_rgb(0_0_0/0.07)] overflow-hidden"
        >
          <div class="flex items-center justify-between p-5">
            <h2 class="text-[14px] font-bold text-[#012d53] m-0">Browse</h2>
            <a
              href="/browse"
              class="text-[12px] font-semibold text-blue-500 hover:text-blue-600 hover:underline no-underline transition-colors"
            >
              View all
            </a>
          </div>
          <div class="flex flex-col">
            {
              featuredCategories.map((cat) => (
                <a
                  href={`/browse/${stripMd(cat.id)}`}
                  class="feed-article group flex gap-4 p-4  border-b border-[#dce8f2] hover:bg-[#f4f7fa] bg-white  transition-all no-underline"
                  style={`--cat-color: ${cat.data.color}`}
                  aria-label={`Browse ${cat.data.name}`}
                >
                  <div
                    class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0"
                    style={`background: ${cat.data.bgColor ?? "#dce8f2"}`}
                    aria-hidden="true"
                  >
                    <i
                      class:list={[cat.data.icon, "text-sm"]}
                      style={`color: ${cat.data.color}`}
                      aria-hidden="true"
                    />
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="cat-mini-title text-[14px] font-semibold text-[#0A1628] leading-snug m-0 transition-colors">
                      {cat.data.name}
                    </p>
                    <p class="text-[12px] text-[#9CA3AF] mt-0.5 m-0">
                      {articleCount(stripMd(cat.id))} articles
                    </p>
                  </div>
                  <i
                    class="ri-arrow-right-up-line text-sm ml-auto shrink-0 mt-1 opacity-0 group-hover:opacity-100 transition-opacity"
                    style={`color: ${cat.data.color}`}
                    aria-hidden="true"
                  />
                </a>
              ))
            }
          </div>
        </div>
      </aside>

      <!-- ══════════════════════════════════════════════════════
           CENTER — Feed
      ══════════════════════════════════════════════════════ -->
      <main class="col-span-1 lg:col-span-2 flex flex-col gap-5 min-w-0">
        <!-- Latest Articles -->
        <section
          class="bg-white rounded-2xl shadow-[0_1px_4px_rgb(0_0_0/0.07)] overflow-hidden"
        >
          <div class="flex items-center justify-between p-5">
            <h2
              class="text-[15px] font-bold text-[#012d53] m-0 flex items-center gap-2"
            >
              <i class="ri-sparkling-line text-blue-500" aria-hidden="true"></i>
              What's New
            </h2>
            <a
              href="/browse"
              class="text-[12px] font-semibold text-blue-500 hover:text-blue-600 hover:underline no-underline transition-colors flex items-center gap-1"
            >
              View all <i class="ri-arrow-right-s-line" aria-hidden="true"></i>
            </a>
          </div>
          <div class="flex flex-col">
            {
              feedArticles.map((article) => (
                <a
                  href={`/browse/${article.categorySlug}/${article.slug}`}
                  class="feed-article group flex gap-4 p-4  border-b border-[#dce8f2] hover:bg-[#f4f7fa] bg-white hover:border-transparent hover:shadow-[0_4px_16px_-4px_rgb(0_0_0/0.12)] transition-all no-underline"
                >
                  <div
                    class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-0.5"
                    style={`background: ${article.categoryBg}`}
                    aria-hidden="true"
                  >
                    <i
                      class:list={[article.categoryIcon, "text-sm"]}
                      style={`color: ${article.categoryColor}`}
                      aria-hidden="true"
                    />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span
                        class="text-[11px] font-bold uppercase tracking-wider"
                        style={`color: ${article.categoryColor}`}
                      >
                        {article.categoryName}
                      </span>
                      <span class="text-[#dce8f2]" aria-hidden="true">
                        ·
                      </span>
                      <span class="text-[11px] text-[#9CA3AF]">
                        {article.readTime}
                      </span>
                      <span class="text-[#dce8f2]" aria-hidden="true">
                        ·
                      </span>
                      <span class="text-[11px] text-[#9CA3AF]">
                        {new Date(article.dateCreated).toLocaleDateString(
                          "en-US",
                          { month: "short", day: "numeric" },
                        )}
                      </span>
                    </div>
                    <h3 class="feed-title text-[14px] font-semibold text-[#0A1628] leading-snug m-0 line-clamp-1 transition-colors">
                      {article.title}
                    </h3>
                    <p class="text-[12px] text-[#6B7280] mt-1 m-0 line-clamp-2 leading-relaxed">
                      {article.summary}
                    </p>
                  </div>
                  <i
                    class="ri-arrow-right-up-line text-sm ml-auto shrink-0 mt-1 opacity-0 group-hover:opacity-100 transition-opacity"
                    style={`color: ${article.categoryColor}`}
                    aria-hidden="true"
                  />
                </a>
              ))
            }
          </div>
        </section>

        <!-- Team Announcements -->
        <section
          class="bg-white rounded-2xl shadow-[0_1px_4px_rgb(0_0_0/0.07)] overflow-hidden"
        >
          <div class="flex items-center justify-between p-5">
            <h2
              class="text-[15px] font-bold text-[#012d53] m-0 flex items-center gap-2"
            >
              <i class="ri-megaphone-line text-blue-500" aria-hidden="true"></i>
              Team Announcements
            </h2>
            <span
              class="text-[11px] font-bold text-white bg-[#41be5e] px-2.5 py-0.5 rounded-full"
              >2 new</span
            >
          </div>

          <div class="flex flex-col">
            <!-- Post 1 -->
            <div class="p-4 hover:bg-[#f4f7fa] border-b border-[#dce8f2]">
              <div class="flex items-start gap-3">
                <div
                  class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 text-white text-[12px] font-bold"
                  style="background: linear-gradient(135deg, #012d53 0%, #1e5c9e 100%);"
                  aria-hidden="true"
                >
                  SM
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1 flex-wrap">
                    <span class="text-[13px] font-bold text-[#012d53]"
                      >Sarah Mitchell</span
                    >
                    <span class="text-[11px] text-[#9CA3AF] font-medium"
                      >Team Lead</span
                    >
                    <span class="text-[#dce8f2]" aria-hidden="true">·</span>
                    <span class="text-[11px] text-[#9CA3AF]">2h ago</span>
                    <span
                      class="ml-auto text-[10px] font-bold uppercase tracking-wider text-[#41be5e] bg-[#e6f7eb] px-2 py-0.5 rounded-full"
                      >New</span
                    >
                  </div>
                  <p class="text-[13px] text-[#374151] leading-relaxed m-0">
                    Q2 is off to a strong start — great work everyone. Updated
                    objection scripts are now live in the KB. Make sure you're
                    using the new rate-framing language on all inbound calls.
                  </p>
                  <a
                    href="/browse/objection-handling"
                    class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#012d53] mt-2 no-underline hover:text-[#41be5e] transition-colors"
                  >
                    <i class="ri-book-open-line text-xs" aria-hidden="true"></i>
                    Objection Handling
                  </a>
                </div>
              </div>
            </div>

            <!-- Post 2 -->
            <div class="p-4 hover:bg-[#f4f7fa] border-b border-[#dce8f2]">
              <div class="flex items-start gap-3">
                <div
                  class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 text-white text-[12px] font-bold"
                  style="background: linear-gradient(135deg, #1c2e44 0%, #4a6785 100%);"
                  aria-hidden="true"
                >
                  DR
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1 flex-wrap">
                    <span class="text-[13px] font-bold text-[#012d53]"
                      >David Reyes</span
                    >
                    <span class="text-[11px] text-[#9CA3AF] font-medium"
                      >Compliance</span
                    >
                    <span class="text-[#dce8f2]" aria-hidden="true">·</span>
                    <span class="text-[11px] text-[#9CA3AF]">Yesterday</span>
                    <span
                      class="ml-auto text-[10px] font-bold uppercase tracking-wider text-[#41be5e] bg-[#e6f7eb] px-2 py-0.5 rounded-full"
                      >New</span
                    >
                  </div>
                  <p class="text-[13px] text-[#374151] leading-relaxed m-0">
                    Reminder: updated call recording disclosure is required on
                    ALL outbound calls effective April 1. The exact language is
                    in the Compliance section — please review before your next
                    session.
                  </p>
                  <a
                    href="/browse/compliance-legal"
                    class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#012d53] mt-2 no-underline hover:text-[#41be5e] transition-colors"
                  >
                    <i class="ri-shield-check-line text-xs" aria-hidden="true"
                    ></i>
                    Compliance & Legal
                  </a>
                </div>
              </div>
            </div>

            <!-- Post 3 -->
            <div class="p-4 hover:bg-[#f4f7fa] border-b border-[#dce8f2]">
              <div class="flex items-start gap-3">
                <div
                  class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 text-white text-[12px] font-bold"
                  style="background: linear-gradient(135deg, #0d5e2e 0%, #41be5e 100%);"
                  aria-hidden="true"
                >
                  MK
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1 flex-wrap">
                    <span class="text-[13px] font-bold text-[#012d53]"
                      >Marcus Kim</span
                    >
                    <span class="text-[11px] text-[#9CA3AF] font-medium"
                      >Sales Director</span
                    >
                    <span class="text-[#dce8f2]" aria-hidden="true">·</span>
                    <span class="text-[11px] text-[#9CA3AF]">Apr 7</span>
                  </div>
                  <p class="text-[13px] text-[#374151] leading-relaxed m-0">
                    New SIC codes have been added to our approved industries
                    list — several previously borderline verticals are now
                    eligible. Review Funding Amounts before your next
                    qualification call.
                  </p>
                  <a
                    href="/browse/rbf-business-loans/funding-amounts"
                    class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-[#012d53] mt-2 no-underline hover:text-[#41be5e] transition-colors"
                  >
                    <i
                      class="ri-money-dollar-circle-line text-xs"
                      aria-hidden="true"></i>
                    Funding Amounts
                  </a>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- What's New -->
        <section
          class="hidden bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <h2
            class="text-[15px] font-bold text-[#012d53] m-0 mb-4 flex items-center gap-2"
          >
            <i class="ri-sparkling-line text-blue-500" aria-hidden="true"></i>
            What's New
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div
              class="p-4 rounded-xl border-l-4 border-[#41be5e] bg-[#f4f7fa]"
            >
              <div class="flex items-center gap-2 mb-2">
                <span
                  class="text-[10px] font-bold uppercase tracking-wider text-white bg-[#41be5e] px-2 py-0.5 rounded-full"
                  >Updated</span
                >
                <span class="text-[11px] text-[#9CA3AF]">Apr 8</span>
              </div>
              <p class="text-[13px] font-bold text-[#012d53] m-0 mb-1">
                72-Hour Funding — Expanded
              </p>
              <p class="text-[12px] text-[#6B7280] m-0 leading-relaxed">
                Eligible industries expanded. New SIC codes now qualify across
                Tier 1 and 2.
              </p>
            </div>

            <div
              class="p-4 rounded-xl border-l-4 border-[#1e5c9e] bg-[#f4f7fa]"
            >
              <div class="flex items-center gap-2 mb-2">
                <span
                  class="text-[10px] font-bold uppercase tracking-wider text-white bg-[#1e5c9e] px-2 py-0.5 rounded-full"
                  >New Script</span
                >
                <span class="text-[11px] text-[#9CA3AF]">Apr 5</span>
              </div>
              <p class="text-[13px] font-bold text-[#012d53] m-0 mb-1">
                Closing & Next Steps
              </p>
              <p class="text-[12px] text-[#6B7280] m-0 leading-relaxed">
                New approved closing script covering document collection and 24h
                follow-up cadence.
              </p>
            </div>

            <div
              class="p-4 rounded-xl border-l-4 border-[#4a6785] bg-[#f4f7fa]"
            >
              <div class="flex items-center gap-2 mb-2">
                <span
                  class="text-[10px] font-bold uppercase tracking-wider text-white bg-[#4a6785] px-2 py-0.5 rounded-full"
                  >Compliance</span
                >
                <span class="text-[11px] text-[#9CA3AF]">Apr 1</span>
              </div>
              <p class="text-[13px] font-bold text-[#012d53] m-0 mb-1">
                Recording Disclosure Update
              </p>
              <p class="text-[12px] text-[#6B7280] m-0 leading-relaxed">
                Updated required disclosure language effective Q2. Prohibited
                phrases list also revised.
              </p>
            </div>

            <div
              class="p-4 rounded-xl border-l-4 border-[#0e6b8e] bg-[#f4f7fa]"
            >
              <div class="flex items-center gap-2 mb-2">
                <span
                  class="text-[10px] font-bold uppercase tracking-wider text-white bg-[#0e6b8e] px-2 py-0.5 rounded-full"
                  >Tool</span
                >
                <span class="text-[11px] text-[#9CA3AF]">Mar 28</span>
              </div>
              <p class="text-[13px] font-bold text-[#012d53] m-0 mb-1">
                Salesforce Quick Guide v2
              </p>
              <p class="text-[12px] text-[#6B7280] m-0 leading-relaxed">
                Updated for the new pipeline dashboard layout. Includes
                Opportunity stage shortcuts.
              </p>
            </div>
          </div>
        </section>
      </main>

      <!-- ══════════════════════════════════════════════════════
           RIGHT — Calendar · Schedule · Goals · Alerts
      ══════════════════════════════════════════════════════ -->
      <aside class="flex flex-col gap-4 lg:sticky lg:top-[80px]">
        <!-- Calendar -->
        <div
          class="bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <div class="flex items-center justify-between mb-4">
            <div>
              <p
                class="text-[30px] font-extrabold text-[#012d53] leading-none m-0"
              >
                9
              </p>
              <p class="text-[12px] text-[#9CA3AF] font-medium mt-0.5 m-0">
                Wednesday, April 2026
              </p>
            </div>
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center"
              style="background: linear-gradient(135deg, #012d53 0%, #1e5c9e 100%);"
              aria-hidden="true"
            >
              <i class="ri-calendar-2-line text-white text-base"></i>
            </div>
          </div>

          <div role="grid" aria-label="April 2026">
            <div class="grid grid-cols-7 mb-1" role="row">
              {
                ["S", "M", "T", "W", "T", "F", "S"].map((d) => (
                  <span
                    role="columnheader"
                    class="text-[10px] font-bold text-[#9CA3AF] text-center py-1"
                  >
                    {d}
                  </span>
                ))
              }
            </div>
            {
              calWeeks.map((week) => (
                <div class="grid grid-cols-7" role="row">
                  {week.map((day) =>
                    day !== null ? (
                      <span
                        role="gridcell"
                        class:list={[
                          "text-[12px] text-center py-1.5 rounded-lg font-medium leading-none",
                          day === todayDate
                            ? "bg-[#012d53] text-white font-bold"
                            : "text-[#374151] hover:bg-[#f4f7fa] cursor-default",
                        ]}
                        aria-current={day === todayDate ? "date" : undefined}
                      >
                        {day}
                      </span>
                    ) : (
                      <span role="gridcell" aria-hidden="true" />
                    ),
                  )}
                </div>
              ))
            }
          </div>
        </div>

        <!-- Today's Schedule -->
        <div
          class="bg-white rounded-2xl p-5 shadow-[0_1px_4px_rgb(0_0_0/0.07)]"
        >
          <h2
